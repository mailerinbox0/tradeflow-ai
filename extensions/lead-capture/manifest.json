{
  "manifest_version": 3,
  "name": "TradeFlow Mailing",
  "version": "1.0.0",
  "description": "Search emails against TradeFlow leads, capture new leads, and send the admin campaign message.",
  "action": {
    "default_title": "TradeFlow Mail Search",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/search16.png",
      "32": "icons/search32.png",
      "48": "icons/search48.png"
    }
  },
  "icons": {
    "16": "icons/search16.png",
    "32": "icons/search32.png",
    "48": "icons/search48.png"
  },
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["http://localhost:3000/*", "http://127.0.0.1:3000/*", "https://*/*"],
  "background": {
    "service_worker": "background.js"
  }
}
